# ZOE NEURAL IDENTITY AGENT - ENVIRONMENT TEMPLATE 🛰️⚙️
# ---------------------------------------------------
# Salin file ini menjadi .env dan isi dengan data Anda.

# 🧠 AI BRAIN (Groq Cloud)
# Ambil API Key di: https://console.groq.com/keys
# Anda bisa memasukkan banyak key dipisah koma untuk sistem rotasi otomatis.
GROQ_API_KEYS=gsk_key1, gsk_key2, gsk_key3

# 💾 DATABASE (MongoDB Persistence)
# Gunakan MongoDB Atlas (Cloud) atau koneksi lokal.
MONGODB_URI=mongodb://localhost:27017/zoe_neural_db

# 📞 WHATSAPP IDENTITY
# OWNER_LID: Identitas unik WA Anda (LID atau Nomor HP tanpa simbol)
OWNER_LID=140089552310506
OWNER_NAME=Neionri
BOT_NAME=Zoe Core
PREFIX=.
PORT=3000

# ⚙️ OPTIONAL CONFIG
# PAIRING_NUMBER=628xxxx
# DEBUG_MODE=true
