# ZOE NEURAL IDENTITY AGENT - ENVIRONMENT TEMPLATE 🛰️⚙️
# ---------------------------------------------------
# Salin file ini menjadi .env dan isi dengan data Anda.
# JANGAN PERNAH membocorkan file .env asli Anda ke publik!

# 🧠 AI BRAIN (Groq Cloud)
# Ambil API Key di: https://console.groq.com/keys
GROQ_API_KEY=gsk_your_api_key_here

# 💾 DATABASE (MongoDB Persistence)
# Gunakan MongoDB Atlas (Cloud) atau koneksi lokal.
MONGODB_URI=mongodb://localhost:27017/zoe_neural_db

# 📞 WHATSAPP CONNECTIVITY
# OWNER_NUMBER: Nomor Anda (Master) tanpa simbol + atau -
OWNER_NUMBER=628xxxx

# PAIRING_NUMBER: Nomor yang akan digunakan Zoe
PAIRING_NUMBER=628xxxx

# ⚙️ OPTIONAL CONFIG
# SESSION_ID=zoe-neural-session
# PORT=3000
# DEBUG_MODE=true
