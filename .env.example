# ZOE NEURAL IDENTITY AGENT - ENVIRONMENT TEMPLATE 🛰️⚙️
# ---------------------------------------------------
# Salin file ini menjadi .env dan isi dengan data Anda.

# 🧠 AI BRAIN (Groq Cloud)
# Ambil API Key di: https://console.groq.com/keys
GROQ_API_KEYS=gsk_key1

# 💾 DATABASE (Neural Persistence Matrix)
# Gunakan MongoDB Atlas (Cloud) atau koneksi lokal.
MONGODB_URI=mongodb://localhost:27017/zoe_neural_db

# 📞 WHATSAPP IDENTITY
OWNER_NUMBER=628xxxx               # Nomor WhatsApp Master (Tanpa simbol)
OWNER_LID=1400xxx                 # Identitas Unik Master (LID)
OWNER_NAME=BossName               # Nama Master yang Zoe panggil
BOT_NAME=Zoe Core                 # Nama Raga Zoe
DASHBOARD_PIN=1234                # PIN Akses Website Dashboard
PREFIX=.                          # Prefix Perintah
PORT=3000                        # Port Dashboard Server

# ⚙️ OPTIONAL CONFIG (Neural Specs)
DEBUG_MODE=false                  # Mode Debug untuk Log Syaraf Detail
PAIRING_NUMBER=628xxxx            # Pre-set nomor untuk login pairing
